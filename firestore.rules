rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based check
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Phase 4: Entity Validation
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.price is number && data.price >= 0
          && data.category is string && data.category.size() <= 50
          && data.image is string && data.image.size() <= 1000;
    }

    function isValidOrder(data) {
      return data.items is list && data.items.size() > 0 && data.items.size() <= 50
          && data.total is number && data.total >= 0
          && data.status in ['pending', 'completed', 'cancelled']
          && data.createdAt == request.time
          && data.customerInfo is map
          && data.customerInfo.name is string && data.customerInfo.name.size() <= 100
          && data.customerInfo.phone is string && data.customerInfo.phone.size() <= 20
          && data.customerInfo.address is string && data.customerInfo.address.size() <= 500;
    }

    // Collection: Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection: Orders
    match /orders/{orderId} {
      // Users can only see their own orders if they were signed in, 
      // but here we allow anyone to CREATE an order (guest checkout).
      // Reading orders should be restricted to admins.
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Collection: Admins
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
